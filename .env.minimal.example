# === 部署模式 ===
DEPLOY_MODE=minimal

# === 功能开关 ===
ENABLE_API=false
ENABLE_OAUTH=false
ENABLE_CRAWLER=true

# === Meilisearch ===
MEILISEARCH_HOST=localhost
MEILISEARCH_PORT=7700
MEILISEARCH_API_KEY=
MEILI_MASTER_KEY=

# === 站点配置 ===
SITE_URL=https://{{DOMAIN}}
SITE_NAME={{SITE_NAME}}
SITE_TITLE={{SITE_TITLE}}

# === Flask (完整模式) ===
FLASK_SECRET=
FLASK_PORT=5000

# === GitHub OAuth (完整模式) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_USERS=

# === 可选 ===
# RATE_LIMIT_PER_MINUTE=10
# RATE_LIMIT_PER_DAY=1000
# RATE_LIMIT_PER_MONTH=2000
