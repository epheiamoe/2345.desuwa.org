[Unit]
Description={{SITE_NAME}} API Service
After=network.target

[Service]
Type=simple
User={{SERVICE_USER}}
Group={{SERVICE_GROUP}}
WorkingDirectory={{PROJECT_DIR}}/api
Environment="PATH={{PROJECT_DIR}}/venv/bin"
EnvironmentFile={{PROJECT_DIR}}/.env
ExecStart={{PROJECT_DIR}}/venv/bin/gunicorn -w 4 -b 127.0.0.1:{{FLASK_PORT}} wsgi:app
ExecReload=/bin/kill -HUP $MAINPID
KillMode=mixed
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
