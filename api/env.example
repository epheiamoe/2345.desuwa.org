# 复制此文件为 .env 并填写实际值
# cp env.example .env

# GitHub OAuth（在 https://github.com/settings/developers 创建 OAuth App）
# Authorization callback URL: https://your-domain.com/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Flask Secret Key（必填，用于 session 签名，推荐使用 openssl rand -hex 32 生成）
FLASK_SECRET=

# 管理员 GitHub 用户名（逗号分隔，如: admin1,admin2）
ADMIN_USERS=

# Meilisearch 配置
MEILISEARCH_HOST=localhost
MEILISEARCH_PORT=7700
MEILISEARCH_INDEX=trans_resources
MEILISEARCH_API_KEY=

# 站点 URL（用于 OAuth 回调）
SITE_URL=https://your-domain.com

# API 配置
API_PORT=5000
